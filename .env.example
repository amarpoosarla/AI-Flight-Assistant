# ============================================================
# AI Flight Assistant — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local or any file with real secrets
# ============================================================

# ------------------------------------
# App Environment
# Values: development | staging | production
# ------------------------------------
NEXT_PUBLIC_ENV=development

# Public API base URL for this environment
NEXT_PUBLIC_API_URL=http://localhost:3000

# ------------------------------------
# Supabase
# Get from: https://supabase.com → Project → Settings → API
# ------------------------------------
# Public anon key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, never expose to client
# NOT currently used at runtime (all DB access uses anon key + RLS).
# Provisioned here for future admin/webhook operations that need to bypass RLS.
# Leave blank if you have not set up admin features yet.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------
# NVIDIA NIM (LLM for AI Planner)
# Get from: https://build.nvidia.com → select a model → Get API Key
# Model: meta/llama-3.3-70b-instruct (supports function calling)
# ------------------------------------
NVIDIA_API_KEY=your-nvidia-api-key-here

# ------------------------------------
# Amadeus Flight API
# Get from: https://developers.amadeus.com
# Use "test" hostname for sandbox, "production" for live
# ------------------------------------
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
AMADEUS_HOSTNAME=test

# ------------------------------------
# Admin / Ops
# Generate with: openssl rand -hex 32
# Used to protect the /admin/health endpoint
# ------------------------------------
HEALTH_CHECK_SECRET=your-random-secret-here
